# ===== LLM =====
# DeepSeek（首选，兼容 OpenAI 协议）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 备选（后续接入）
# DASHSCOPE_API_KEY=
# ZHIPU_API_KEY=

# ===== 运行时 =====
LOG_LEVEL=INFO
DATA_DIR=./data

# ===== Git 拉取 =====
GIT_CLONE_TIMEOUT=120
GIT_CLONE_DEPTH=0
GIT_CONCURRENCY=4
