# osAgent 生产环境变量（会被 systemd 加载）
# 目标路径：/etc/osagent/osagent.env
# 权限：640, root:osagent

# ===== LLM =====
DEEPSEEK_API_KEY=sk-REPLACE_ME
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== 运行时 =====
LOG_LEVEL=INFO
# 数据放系统盘外挂目录（40G 系统盘够用；将来涨了可以挂云盘）
DATA_DIR=/var/lib/osagent/data

# ===== API Key 保护（生产必开）=====
# 生成方法：openssl rand -hex 32
# 未设置 → 中间件透传（等于开发模式）；设置了 → 写接口必须 header X-API-Key
OSAGENT_API_KEY=REPLACE_ME_WITH_openssl_rand_hex_32

# ===== Git 拉取 =====
# 2G 内存机器降并发，避免 OOM
GIT_CLONE_TIMEOUT=180
GIT_CLONE_DEPTH=1
GIT_CONCURRENCY=2
